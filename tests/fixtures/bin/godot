#!/usr/bin/env python3
"""Stub 'godot': --version, laser_tag eval, lux apply, and portability check."""
import argparse, json, sys
from pathlib import Path


def main():
    argv = [x for x in sys.argv[1:] if x != "--"]
    if "--version" in argv:
        print("4.7.stable.official"); return 0

    p = argparse.ArgumentParser()
    p.add_argument("--headless", action="store_true")
    p.add_argument("--path", default="")
    # laser_tag
    p.add_argument("--lasertag-eval", action="store_true")
    p.add_argument("--scene", default="")
    p.add_argument("--seed", type=int, default=0)
    p.add_argument("--runs", type=int, default=8)
    p.add_argument("--json", default="")
    p.add_argument("--csv", default="")
    # lux apply
    p.add_argument("--lux-apply", action="store_true")
    p.add_argument("--preset", default="")
    p.add_argument("--quality", default="standard")
    p.add_argument("--lights", default="")
    p.add_argument("--capture", action="append", default=[])
    p.add_argument("--out", default="")
    # portability
    p.add_argument("--lf-portability-check", action="store_true")
    a, _ = p.parse_known_args(argv)

    if a.lasertag_eval and a.json:
        jp = Path(a.json); jp.parent.mkdir(parents=True, exist_ok=True)
        jp.write_text(json.dumps({"score": 70 + (a.seed % 20), "grade": "B",
                                  "runs": a.runs, "overexposed_zones": [],
                                  "blind_zones": []}, sort_keys=True))
        if a.csv:
            cp = Path(a.csv); cp.parent.mkdir(parents=True, exist_ok=True)
            cp.write_text("run,score\n0,70\n")
        return 0

    if a.lux_apply and a.out:
        out = Path(a.out); out.mkdir(parents=True, exist_ok=True)
        # Presentation roots only; gameplay nodes stay outside them.
        (out / "lux.applied.tscn").write_text(
            '[gd_scene format=3]\n[node name="Mission" type="Node3D"]\n'
            '[node name="LuxLevel" type="Node3D" parent="."]\n'
            '[node name="Functional" type="Node3D" parent="."]\n')
        (out / "lux.quality.json").write_text(json.dumps(
            {"preset": a.preset, "quality_tier": a.quality,
             "captures": a.capture}, sort_keys=True))
        (out / "lux.validation.json").write_text(json.dumps({"issues": []}, sort_keys=True))
        for state in a.capture:
            (out / f"preview_{state}.png").write_bytes(b"PNG-" + state.encode())
        return 0

    if a.lf_portability_check:
        # A clean-project import succeeds if mission.tscn exists in --path.
        proj = Path(a.path)
        scene = proj / "mission.tscn"
        if scene.exists():
            print("scene instantiated ok")
            return 0
        print("Parse Error: mission.tscn missing")
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
